---
// src/components/AssessmentPopup.astro
// Shows a popup after 30 seconds offering the free IT assessment checklist.
// Uses sessionStorage so it only appears once per browser session.
// Does NOT show on the /free-assessment or /contact pages.
---

<!-- Assessment Popup -->
<div
  id="assessment-popup"
  class="hidden fixed bottom-6 right-6 z-50 max-w-sm w-full"
  role="dialog"
  aria-label="Free IT Assessment offer"
>
  <div class="bg-navy-900 border border-cyan-400/30 rounded-2xl shadow-2xl shadow-navy-900/50 overflow-hidden">

    <!-- Top accent bar -->
    <div class="bg-cyan-400 h-1 w-full"></div>

    <div class="p-5">
      <!-- Header -->
      <div class="flex items-start justify-between gap-3 mb-3">
        <div class="flex items-center gap-2">
          <span class="text-2xl">🔍</span>
          <p class="text-xs font-bold uppercase tracking-wider text-cyan-400">Free Resource</p>
        </div>
        <button
          id="popup-close"
          class="text-slate-500 hover:text-white transition text-xl leading-none mt-0.5 flex-shrink-0"
          aria-label="Close"
        >
          ×
        </button>
      </div>

      <!-- Content -->
      <h3 class="text-white font-extrabold text-base leading-snug mb-2">
        Is Your Business IT Actually Secure?
      </h3>
      <p class="text-slate-400 text-sm leading-relaxed mb-4">
        Use our free IT assessment checklist to find out — takes less than 5 minutes and reveals your biggest vulnerabilities.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col gap-2">
        <a
          href="/free-assessment"
          id="popup-cta"
          class="bg-cyan-400 text-navy-900 font-bold text-sm text-center py-2.5 px-4 rounded-lg hover:bg-cyan-300 transition"
        >
          Take the Free Checklist →
        </a>
        <button
          id="popup-dismiss"
          class="text-slate-500 hover:text-slate-300 text-xs text-center transition py-1"
        >
          No thanks, I'll skip this
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'wt_popup_shown';
  const DELAY_MS = 30000; // 30 seconds

  const popup = document.getElementById('assessment-popup');
  const closeBtn = document.getElementById('popup-close');
  const dismissBtn = document.getElementById('popup-dismiss');
  const ctaBtn = document.getElementById('popup-cta');

  // Don't show on the free-assessment or contact pages
  const currentPath = window.location.pathname;
  const suppressedPaths = ['/free-assessment', '/contact', '/signin'];
  const isSuppressed = suppressedPaths.some(p => currentPath.startsWith(p));

  // Only show once per session
  const alreadyShown = sessionStorage.getItem(STORAGE_KEY);

  function showPopup() {
    if (!popup) return;
    popup.classList.remove('hidden');
    // Animate in from the right
    popup.style.transform = 'translateX(120%)';
    popup.style.transition = 'transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        popup.style.transform = 'translateX(0)';
      });
    });
  }

  function hidePopup() {
    if (!popup) return;
    popup.style.transform = 'translateX(120%)';
    setTimeout(() => popup.classList.add('hidden'), 400);
  }

  function dismissForSession() {
    sessionStorage.setItem(STORAGE_KEY, '1');
    hidePopup();
  }

  if (!isSuppressed && !alreadyShown) {
    setTimeout(showPopup, DELAY_MS);
  }

  closeBtn?.addEventListener('click', dismissForSession);
  dismissBtn?.addEventListener('click', dismissForSession);
  ctaBtn?.addEventListener('click', () => sessionStorage.setItem(STORAGE_KEY, '1'));
</script>
