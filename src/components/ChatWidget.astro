---
// ChatWidget.astro — floating AI chat widget for wisetech.ca
// No imports needed; fully self-contained
---

<!-- Chat toggle button -->
<button
  id="chat-toggle"
  aria-label="Open WiseTech support chat"
  style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:50;width:56px;height:56px;border-radius:9999px;background:#0f172a;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 14px rgba(0,0,0,0.35);transition:box-shadow 0.2s;"
  onmouseenter="this.style.boxShadow='0 0 0 3px #22d3ee,0 4px 14px rgba(0,0,0,0.35)'"
  onmouseleave="this.style.boxShadow='0 4px 14px rgba(0,0,0,0.35)'"
>
  <!-- Chat icon (shown when closed) -->
  <svg id="icon-chat" xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="#22d3ee" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
  </svg>
  <!-- X icon (shown when open) -->
  <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="#22d3ee" stroke-width="2" aria-hidden="true" style="display:none;">
    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
  </svg>
</button>

<!-- Chat panel -->
<div
  id="chat-panel"
  role="dialog"
  aria-label="WiseTech Support Chat"
  aria-modal="true"
  style="display:none;position:fixed;bottom:5.5rem;right:1.5rem;z-index:50;width:340px;max-width:90vw;height:500px;max-height:80vh;border-radius:1rem;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.28);display:none;flex-direction:column;font-family:ui-sans-serif,system-ui,sans-serif;"
>
  <!-- Header -->
  <div style="background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);padding:1rem 1.25rem;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
    <div style="display:flex;align-items:center;gap:0.75rem;">
      <div style="width:36px;height:36px;border-radius:9999px;background:#22d3ee;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#0f172a" stroke-width="2.2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
      </div>
      <div>
        <div style="color:#fff;font-weight:700;font-size:0.95rem;line-height:1.2;">WiseTech Support</div>
        <div style="color:#94a3b8;font-size:0.75rem;">Typically replies instantly</div>
      </div>
    </div>
    <button
      id="chat-close"
      aria-label="Close chat"
      style="background:transparent;border:none;cursor:pointer;padding:0.25rem;border-radius:0.375rem;transition:background 0.15s;"
      onmouseenter="this.style.background='rgba(255,255,255,0.1)'"
      onmouseleave="this.style.background='transparent'"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#94a3b8" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Messages area -->
  <div id="chat-messages" style="flex:1;overflow-y:auto;padding:1rem;background:#f8fafc;display:flex;flex-direction:column;gap:0.75rem;">
    <!-- Messages injected by JS -->
  </div>

  <!-- Typing indicator (hidden by default) -->
  <div id="chat-typing" style="display:none;padding:0 1rem 0.5rem;background:#f8fafc;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:#fff;border:1px solid #e2e8f0;border-radius:1rem;padding:0.5rem 0.75rem;">
      <span class="chat-dot" style="width:7px;height:7px;border-radius:9999px;background:#94a3b8;animation:chatBounce 1.2s infinite 0s;"></span>
      <span class="chat-dot" style="width:7px;height:7px;border-radius:9999px;background:#94a3b8;animation:chatBounce 1.2s infinite 0.2s;"></span>
      <span class="chat-dot" style="width:7px;height:7px;border-radius:9999px;background:#94a3b8;animation:chatBounce 1.2s infinite 0.4s;"></span>
    </div>
  </div>

  <!-- Input row -->
  <div style="background:#fff;border-top:1px solid #e2e8f0;padding:0.75rem 1rem;display:flex;gap:0.5rem;flex-shrink:0;">
    <input
      id="chat-input"
      type="text"
      placeholder="Type a message…"
      aria-label="Chat message"
      maxlength="500"
      style="flex:1;border:1px solid #cbd5e1;border-radius:0.5rem;padding:0.5rem 0.75rem;font-size:0.875rem;color:#1e293b;outline:none;background:#f8fafc;transition:border-color 0.15s;"
      onfocus="this.style.borderColor='#22d3ee';this.style.background='#fff';"
      onblur="this.style.borderColor='#cbd5e1';this.style.background='#f8fafc';"
    />
    <button
      id="chat-send"
      aria-label="Send message"
      style="background:#22d3ee;border:none;border-radius:0.5rem;padding:0.5rem 0.75rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.15s;flex-shrink:0;"
      onmouseenter="this.style.background='#06b6d4'"
      onmouseleave="this.style.background='#22d3ee'"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#0f172a" stroke-width="2.2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
      </svg>
    </button>
  </div>

  <!-- Footer -->
  <div style="background:#fff;border-top:1px solid #e2e8f0;padding:0.35rem 1rem;text-align:center;font-size:0.7rem;color:#94a3b8;flex-shrink:0;">
    Powered by WiseTech AI &middot; Or call <a href="tel:8884459473" style="color:#22d3ee;text-decoration:none;">888-445-9473</a>
  </div>
</div>

<!-- Bounce animation keyframes -->
<style>
  @keyframes chatBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
    30% { transform: translateY(-5px); opacity: 1; }
  }
</style>

<script is:inline>
(function () {
  var WELCOME = "Hi! 👋 I'm WiseTech's AI assistant. I can answer questions about our managed IT services, pricing, and cybersecurity. How can I help you today?";
  var ERROR_MSG = "I'm having trouble connecting. Please call 888-445-9473.";

  var panel      = document.getElementById('chat-panel');
  var toggleBtn  = document.getElementById('chat-toggle');
  var closeBtn   = document.getElementById('chat-close');
  var messagesEl = document.getElementById('chat-messages');
  var typingEl   = document.getElementById('chat-typing');
  var inputEl    = document.getElementById('chat-input');
  var sendBtn    = document.getElementById('chat-send');
  var iconChat   = document.getElementById('icon-chat');
  var iconClose  = document.getElementById('icon-close');

  var history    = [];   // [{role, content}]
  var isOpen     = false;
  var initialized = false;

  function openPanel() {
    isOpen = true;
    panel.style.display = 'flex';
    iconChat.style.display = 'none';
    iconClose.style.display = 'block';
    toggleBtn.setAttribute('aria-label', 'Close WiseTech support chat');
    if (!initialized) {
      initialized = true;
      appendMessage('assistant', WELCOME);
    }
    inputEl.focus();
  }

  function closePanel() {
    isOpen = false;
    panel.style.display = 'none';
    iconChat.style.display = 'block';
    iconClose.style.display = 'none';
    toggleBtn.setAttribute('aria-label', 'Open WiseTech support chat');
  }

  toggleBtn.addEventListener('click', function () {
    if (isOpen) { closePanel(); } else { openPanel(); }
  });
  closeBtn.addEventListener('click', closePanel);

  // Close on Escape key
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && isOpen) { closePanel(); }
  });

  // Lightweight markdown → HTML renderer for chat bubbles
  function renderMarkdown(text) {
    // Escape HTML entities first
    var s = text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');

    // Process line by line to handle lists
    var lines = s.split('\n');
    var out = '';
    var inUl = false, inOl = false;

    lines.forEach(function(line) {
      var ulM = line.match(/^[\-\*•]\s+(.+)/);
      var olM = line.match(/^(\d+)\.\s+(.+)/);
      if (ulM) {
        if (inOl) { out += '</ol>'; inOl = false; }
        if (!inUl) { out += '<ul style="margin:4px 0 4px 16px;padding:0;">'; inUl = true; }
        out += '<li style="margin:2px 0;">' + ulM[1] + '</li>';
      } else if (olM) {
        if (inUl) { out += '</ul>'; inUl = false; }
        if (!inOl) { out += '<ol style="margin:4px 0 4px 16px;padding:0;">'; inOl = true; }
        out += '<li style="margin:2px 0;">' + olM[2] + '</li>';
      } else {
        if (inUl) { out += '</ul>'; inUl = false; }
        if (inOl) { out += '</ol>'; inOl = false; }
        out += line === '' ? '<br>' : line + '<br>';
      }
    });
    if (inUl) out += '</ul>';
    if (inOl) out += '</ol>';

    // Markdown links [text](url)
    out = out.replace(/\[([^\]]+)\]\((https?:\/\/[^\)]+)\)/g, '<a href="$2" target="_blank" rel="noopener" style="color:#22d3ee;text-decoration:underline;">$1</a>');
    // Bare URLs (not already inside an href)
    out = out.replace(/(?<!href="|">)(https?:\/\/[^\s<"]+)/g, '<a href="$1" target="_blank" rel="noopener" style="color:#22d3ee;text-decoration:underline;">$1</a>');
    // Bold **text** and __text__
    out = out.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    out = out.replace(/__(.+?)__/g, '<strong>$1</strong>');
    // Italic *text* (single, not double)
    out = out.replace(/(?<!\*)\*(?!\*)(.+?)(?<!\*)\*(?!\*)/g, '<em>$1</em>');
    // Inline code
    out = out.replace(/`([^`]+)`/g, '<code style="background:#f1f5f9;padding:1px 4px;border-radius:3px;font-size:0.8em;">$1</code>');
    // Strip trailing line breaks
    out = out.replace(/(<br>\s*)+$/, '');
    return out;
  }

  function appendMessage(role, content) {
    var wrapper = document.createElement('div');
    wrapper.style.display = 'flex';
    wrapper.style.flexDirection = 'column';
    wrapper.style.alignItems = role === 'user' ? 'flex-end' : 'flex-start';

    var bubble = document.createElement('div');
    bubble.style.maxWidth = '85%';
    bubble.style.padding = '0.55rem 0.9rem';
    bubble.style.borderRadius = role === 'user' ? '1rem 1rem 0.25rem 1rem' : '1rem 1rem 1rem 0.25rem';
    bubble.style.fontSize = '0.85rem';
    bubble.style.lineHeight = '1.6';
    bubble.style.wordBreak = 'break-word';

    if (role === 'user') {
      bubble.style.background = '#22d3ee';
      bubble.style.color = '#0f172a';
      bubble.textContent = content; // user messages stay as plain text
    } else {
      // Check for LEAD marker
      var leadMatch = content.match(/\[LEAD:(\{[^}]+\})\]/);
      if (leadMatch) {
        content = content.replace(/\[LEAD:[^\]]+\]/, '').trim();
        try {
          var leadData = JSON.parse(leadMatch[1]);
          // Build plain text transcript
          var transcript = history.map(function(m) {
            return (m.role === 'user' ? 'Visitor: ' : 'WiseTech AI: ') + m.content;
          }).join('\n\n');
          // POST to /api/chat-lead
          fetch('/api/chat-lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: leadData.name || '',
              email: leadData.email || '',
              phone: leadData.phone || '',
              company: leadData.company || '',
              summary: leadData.summary || '',
              transcript: transcript
            })
          }).catch(function() {}); // silent fail — don't block UX
        } catch(e) {}
      }

      // Check for OPTIONS marker
      var optionsMatch = content.match(/\[OPTIONS:\s*([^\]]+)\]/);
      var optionsList = [];
      if (optionsMatch) {
        content = content.replace(/\[OPTIONS:[^\]]+\]/, '').trim();
        // Parse quoted options: "Option 1","Option 2"
        var optStr = optionsMatch[1];
        var optRe = /"([^"]+)"/g;
        var optM;
        while ((optM = optRe.exec(optStr)) !== null) {
          optionsList.push(optM[1]);
        }
      }

      bubble.style.background = '#fff';
      bubble.style.color = '#334155';
      bubble.style.border = '1px solid #e2e8f0';
      bubble.innerHTML = renderMarkdown(content); // bot messages render markdown
    }

    wrapper.appendChild(bubble);

    if (role === 'assistant' && optionsList && optionsList.length > 0) {
      var btnRow = document.createElement('div');
      btnRow.style.cssText = 'display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;max-width:85%;';
      optionsList.forEach(function(opt) {
        var btn = document.createElement('button');
        btn.textContent = opt;
        btn.style.cssText = 'background:#fff;border:1.5px solid #22d3ee;color:#0f172a;border-radius:1rem;padding:5px 12px;font-size:0.78rem;cursor:pointer;transition:background 0.15s;white-space:nowrap;';
        btn.onmouseenter = function() { btn.style.background='#22d3ee'; };
        btn.onmouseleave = function() { btn.style.background='#fff'; };
        btn.addEventListener('click', function() {
          // Remove all option buttons after one is clicked
          btnRow.remove();
          // Send as if user typed it
          inputEl.value = opt;
          sendMessage();
        });
        btnRow.appendChild(btn);
      });
      wrapper.appendChild(btnRow);
    }

    messagesEl.appendChild(wrapper);
    scrollToBottom();
  }

  function scrollToBottom() {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function setLoading(loading) {
    inputEl.disabled = loading;
    sendBtn.disabled = loading;
    sendBtn.style.opacity = loading ? '0.5' : '1';
    typingEl.style.display = loading ? 'block' : 'none';
    if (loading) { scrollToBottom(); }
  }

  async function sendMessage() {
    var text = inputEl.value.trim();
    if (!text) { return; }

    inputEl.value = '';
    appendMessage('user', text);
    history.push({ role: 'user', content: text });
    setLoading(true);

    try {
      var res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history })
      });

      if (!res.ok) { throw new Error('HTTP ' + res.status); }

      var data = await res.json();
      var reply = (data && data.reply) ? data.reply : ERROR_MSG;
      history.push({ role: 'assistant', content: reply });
      appendMessage('assistant', reply);
    } catch (err) {
      appendMessage('assistant', ERROR_MSG);
    } finally {
      setLoading(false);
      inputEl.focus();
    }
  }

  sendBtn.addEventListener('click', sendMessage);
  inputEl.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });
})();
</script>
