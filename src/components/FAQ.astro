---
// src/components/FAQ.astro
interface FAQItem {
  question: string;
  answer: string;
}
interface Props {
  faqs: FAQItem[];
  title?: string;
}
const { faqs, title = 'Frequently Asked Questions' } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer
    }
  }))
};
---

<section class="section-white">
  <div class="container-lg max-w-4xl">
    <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-8">{title}</h2>
    <div class="divide-y divide-gray-200">
      {faqs.map((faq) => (
        <details class="py-5 group">
          <summary class="font-semibold text-slate-900 cursor-pointer list-none flex justify-between items-start gap-4">
            <span>{faq.question}</span>
            <span class="text-cyan-400 text-2xl leading-none flex-shrink-0 mt-0.5 group-open:rotate-45 transition-transform duration-200">+</span>
          </summary>
          <p class="text-slate-600 mt-3 leading-relaxed">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
