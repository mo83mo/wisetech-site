---
// src/components/Footer.astro
const year = new Date().getFullYear();

const serviceLinks = [
  { label: 'Managed IT Services', href: '/services/managed-it' },
  { label: 'Cybersecurity', href: '/services/cybersecurity' },
  { label: 'Backup & Disaster Recovery', href: '/services/backup-disaster-recovery' },
  { label: 'Cloud Solutions', href: '/services/cloud-solutions' },
  { label: 'Network & Infrastructure', href: '/services/network-infrastructure' },
  { label: 'IT Consulting', href: '/services/it-consulting' },
];

const companyLinks = [
  { label: 'About', href: '/about' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="bg-navy-900 text-slate-400 pt-16 pb-8 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/">
          <img src="/images/logo-white.png" alt="WiseTech" class="h-16 w-auto mb-4" />
        </a>
        <p class="text-sm leading-relaxed mb-4">
          Managed IT services and cybersecurity for small businesses in Mississauga and the GTA.
        </p>
        <p class="text-sm font-semibold text-white">📞 <a href="tel:8884459473" class="hover:text-cyan-400 transition">888-445-9473</a></p>
        <p class="text-sm mt-1"><a href="mailto:Info@wisetech.ca" class="hover:text-cyan-400 transition">Info@wisetech.ca</a></p>
        <!-- Social -->
        <div class="mt-4">
          <a
            href="https://www.linkedin.com/company/wisetech-inc"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WiseTech on LinkedIn"
            class="inline-flex items-center gap-2 bg-[#0A66C2] hover:bg-[#004182] text-white text-xs font-semibold px-3 py-2 rounded-lg transition-colors"
          >
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            Follow on LinkedIn
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Services</h3>
        <ul class="flex flex-col gap-2">
          {serviceLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-cyan-400 transition">{link.label}</a>
            </li>
          ))}
          <li>
            <a href="/services" class="text-sm text-cyan-400 hover:text-cyan-300 transition">View All →</a>
          </li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Company</h3>
        <ul class="flex flex-col gap-2">
          {companyLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm hover:text-cyan-400 transition">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Location -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Location</h3>
        <address class="text-sm not-italic leading-relaxed">
          750-2 Robert Speck Parkway<br />
          Mississauga, ON L4Z 1H8<br />
          Canada
        </address>
        <p class="text-sm mt-4 leading-relaxed">
          Serving: Mississauga, Toronto, Brampton, Oakville, and the Greater Toronto Area.
        </p>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-navy-800 pt-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs">
      <p>© {year} WiseTech Inc. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/privacy" class="hover:text-white transition">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
