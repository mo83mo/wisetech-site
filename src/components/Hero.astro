---
// src/components/Hero.astro
interface Props {
  breadcrumb?: string;
  headline: string;
  subheadline: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCta?: { text: string; href: string };
  photo?: string;
  photoAlt?: string;
  showPhone?: boolean;
}

const {
  breadcrumb,
  headline,
  subheadline,
  ctaText = 'Get a Free Assessment',
  ctaHref = '/contact',
  secondaryCta,
  photo,
  photoAlt = 'WiseTech IT Services',
  showPhone = true,
} = Astro.props;
---

<section class="bg-hero-gradient py-16 md:py-20 px-4">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row gap-12 items-center">

    <!-- Text side -->
    <div class="flex-[1.3] max-w-xl">
      {breadcrumb && (
        <div class="inline-flex items-center gap-2 bg-cyan-400/10 border border-cyan-400/30 text-cyan-400 text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-full mb-5">
          {breadcrumb}
        </div>
      )}
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-5">
        {headline}
      </h1>
      <p class="text-slate-400 text-base md:text-lg leading-relaxed mb-7">
        {subheadline}
      </p>
      <div class="flex flex-wrap gap-4 items-center">
        <a href={ctaHref} class="btn-primary">{ctaText}</a>
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn-secondary">{secondaryCta.text}</a>
        )}
        {showPhone && (
          <a href="tel:8884459473" class="text-cyan-400 font-semibold text-sm hover:text-cyan-300 transition">
            📞 888-445-9473
          </a>
        )}
      </div>
    </div>

    <!-- Photo side -->
    {photo && (
      <div class="flex-1 w-full">
        <img
          src={photo}
          alt={photoAlt}
          class="rounded-xl border-2 border-cyan-400/20 w-full object-cover h-64 md:h-80 shadow-2xl"
          loading="eager"
          width="600"
          height="400"
        />
      </div>
    )}
  </div>
</section>
