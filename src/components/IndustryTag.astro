---
// src/components/IndustryTag.astro
interface Props {
  label: string;
  icon: string;
  href: string;
}
const { label, icon, href } = Astro.props;
---

<a href={href} class="inline-flex items-center gap-1.5 bg-indigo-50 border border-indigo-200 text-indigo-700 text-sm font-medium px-4 py-2 rounded-full hover:bg-cyan-400 hover:text-navy-900 hover:border-cyan-400 transition-all">
  <span>{icon}</span>
  <span>{label}</span>
</a>
