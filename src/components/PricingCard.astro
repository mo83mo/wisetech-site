---
// src/components/PricingCard.astro
interface Props {
  name: string;
  monthlyPrice: number;
  annualMonthlyEquiv: number;
  annualYearlyTotal: number;
  annualSavings: number;
  minUsers: number;
  bestFor: string;
  features: string[];
  notIncluded?: string[];
  isPopular?: boolean;
  ctaHref?: string;
}

const {
  name,
  monthlyPrice,
  annualMonthlyEquiv,
  annualYearlyTotal,
  annualSavings,
  minUsers,
  bestFor,
  features,
  notIncluded = [],
  isPopular = false,
  ctaHref = '/contact',
} = Astro.props;
---

<div class:list={[
  'rounded-xl overflow-hidden flex flex-col',
  isPopular ? 'bg-navy-900 border-2 border-cyan-400 shadow-2xl shadow-cyan-400/10' : 'bg-white border border-gray-200 shadow-sm'
]}>
  {isPopular && (
    <div class="bg-cyan-400 text-navy-900 text-xs font-extrabold uppercase tracking-wider text-center py-2">
      Most Popular
    </div>
  )}

  <div class:list={['p-6 border-b text-center', isPopular ? 'bg-navy-800 border-navy-800' : 'bg-slate-50 border-gray-200']}>
    <p class:list={['text-xs font-bold uppercase tracking-wider mb-2', isPopular ? 'text-cyan-400' : 'text-slate-500']}>
      {name}
    </p>
    <div class:list={['text-4xl font-extrabold', isPopular ? 'text-white' : 'text-slate-900']} id={`price-${name.toLowerCase()}`}>
      ${monthlyPrice}
    </div>
    <p class:list={['text-xs mt-1', isPopular ? 'text-slate-400' : 'text-slate-500']}>/user/month</p>
    <p class:list={['text-xs mt-2 font-semibold hidden', isPopular ? 'text-cyan-400' : 'text-cyan-600']} id={`annual-label-${name.toLowerCase()}`}>
      ${annualYearlyTotal}/user/year — billed annually
    </p>
    <p class:list={['text-xs mt-1 hidden', isPopular ? 'text-slate-400' : 'text-slate-500']} id={`save-label-${name.toLowerCase()}`}>
      Save ${annualSavings}/user/year
    </p>
    <p class:list={['text-xs mt-2', isPopular ? 'text-slate-500' : 'text-slate-400']}>
      Min. {minUsers} users
    </p>
  </div>

  <div class="p-6 flex flex-col flex-1 gap-4">
    <p class:list={['text-xs font-bold', isPopular ? 'text-cyan-400' : 'text-slate-700']}>
      Best for: {bestFor}
    </p>
    <ul class="flex flex-col gap-3 flex-1">
      {features.map(f => (
        <li class="flex gap-2 items-start text-sm">
          <span class="text-cyan-400 font-bold mt-0.5 flex-shrink-0">✓</span>
          <span class:list={[isPopular ? 'text-slate-300' : 'text-slate-700']}>{f}</span>
        </li>
      ))}
      {notIncluded.map(f => (
        <li class="flex gap-2 items-start text-sm">
          <span class="text-slate-400 mt-0.5 flex-shrink-0">–</span>
          <span class="text-slate-400">{f}</span>
        </li>
      ))}
    </ul>
    <a
      href={ctaHref}
      class:list={[
        'block text-center font-bold rounded-md px-5 py-3 text-sm transition-colors mt-2',
        isPopular
          ? 'bg-cyan-400 text-navy-900 hover:bg-cyan-300'
          : 'bg-slate-100 text-slate-800 border border-gray-200 hover:bg-cyan-400 hover:text-navy-900 hover:border-cyan-400'
      ]}
    >
      Get Started
    </a>
  </div>
</div>

<script define:vars={{ name, monthlyPrice, annualMonthlyEquiv, annualYearlyTotal, annualSavings }}>
  window.__pricingCards = window.__pricingCards || [];
  window.__pricingCards.push({ name, monthlyPrice, annualMonthlyEquiv, annualYearlyTotal, annualSavings });
</script>
