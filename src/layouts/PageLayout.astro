---
// src/layouts/PageLayout.astro
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AssessmentPopup from '../components/AssessmentPopup.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  additionalSchema?: object;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
  <AssessmentPopup />
</BaseLayout>
