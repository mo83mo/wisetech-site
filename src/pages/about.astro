---
// src/pages/about.astro
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import CTABanner from '../components/CTABanner.astro';

const values = [
  {
    icon: '🤝',
    name: 'Integrity',
    description: 'We give you transparent, honest advice — even when it means recommending against something we could sell you.',
  },
  {
    icon: '✅',
    name: 'Accountability',
    description: 'We own our commitments. If something goes wrong, we fix it — no excuses, no finger-pointing.',
  },
  {
    icon: '🧠',
    name: 'Knowledge',
    description: 'Our team stays current with the latest technology and threats so you benefit from expertise, not guesswork.',
  },
  {
    icon: '💪',
    name: 'Commitment',
    description: 'We treat your business like our own. Your success is the measure of ours.',
  },
  {
    icon: '🔥',
    name: 'Passion',
    description: 'We genuinely love technology and the problems it solves. That enthusiasm shows in how we work.',
  },
];

const differentiators = [
  {
    icon: '📍',
    title: 'Local Mississauga Team',
    description: 'We are based in Mississauga. When you need someone on-site, we are there — not hours away. We understand the GTA business environment and the specific challenges facing local SMBs.',
  },
  {
    icon: '💰',
    title: 'Transparent, Flat-Rate Pricing',
    description: 'No surprise invoices. No hourly billing. One predictable monthly fee covers everything in your plan. We publish our pricing openly — something almost no competitor does.',
  },
  {
    icon: '⚡',
    title: 'Proactive, Not Reactive',
    description: 'We monitor your IT environment 24/7 and resolve most issues before your team notices them. Our job is to prevent problems, not wait for them to happen.',
  },
  {
    icon: '🔒',
    title: 'Cybersecurity as a Foundation',
    description: 'Security is not an add-on at WiseTech — it is built into every plan. Every client gets endpoint protection, email security, and security awareness training included.',
  },
  {
    icon: '🤝',
    title: 'Relationship-First Approach',
    description: 'You will always deal with someone who knows your business. No ticket queues, no call centres, no explaining your situation from scratch every time.',
  },
  {
    icon: '📋',
    title: 'Compliance Expertise',
    description: 'We understand PHIPA, PIPEDA, and PCI DSS. If your industry has regulatory obligations around data and technology, we know what is required and can document it.',
  },
];

const stats = [
  { number: '24/7', label: 'Monitoring & Support' },
  { number: '$99', label: 'Starting per user/month' },
  { number: '8', label: 'Service Areas' },
  { number: '1 hr', label: 'Critical Issue SLA (Advanced)' },
];

const serviceAreas = [
  'Mississauga', 'Toronto', 'Brampton', 'Oakville',
  'Burlington', 'Etobicoke', 'North York', 'Scarborough',
];
---

<PageLayout
  title="About WiseTech | Managed IT Provider in Mississauga"
  description="WiseTech is a Mississauga-based managed IT services provider helping small and medium businesses across the GTA with IT support, cybersecurity, and cloud solutions."
>

  <Hero
    headline="Your Local IT Partner in Mississauga"
    subheadline="WiseTech was built to give Mississauga small businesses access to the kind of professional, proactive IT support that was previously only available to large enterprises — at a price that makes sense for an SMB."
    ctaText="Book a Free Assessment"
    ctaHref="/contact"
    secondaryCta={{ text: 'View Our Services', href: '/services' }}
    photo="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=600&h=400&fit=crop&auto=format"
    photoAlt="WiseTech IT team serving Mississauga businesses"
  />

  <TrustBar />

  <!-- Stats bar -->
  <section class="section-white">
    <div class="container-lg">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map(stat => (
          <div class="text-center p-6 bg-slate-50 rounded-2xl border border-gray-200">
            <div class="text-3xl md:text-4xl font-extrabold text-cyan-500 mb-1">{stat.number}</div>
            <div class="text-slate-600 text-sm font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section class="section-slate">
    <div class="container-lg max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-5">Why We Started WiseTech</h2>
          <div class="flex flex-col gap-4 text-slate-600 leading-relaxed">
            <p>
              Most small businesses in Mississauga have had the same experience with IT: something breaks, they call someone, pay an hourly rate, and hope it does not happen again. It usually does.
            </p>
            <p>
              WiseTech was founded to change that model. We believe small businesses deserve the same proactive, strategic IT support that enterprise companies take for granted — delivered by a local team that understands the Mississauga business community.
            </p>
            <p>
              We focus on relationships, not transactions. When you work with WiseTech, you have a dedicated team that knows your environment, understands your business, and is invested in keeping your technology running — not waiting for it to break.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-1 gap-4">
          <div class="bg-white border border-gray-200 rounded-xl p-5">
            <div class="flex items-start gap-3">
              <span class="text-2xl mt-0.5">🎯</span>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Our Mission</h3>
                <p class="text-slate-600 text-sm leading-relaxed">To deliver tailored IT services that help Mississauga businesses thrive — with transparency, reliability, and genuine commitment to client success.</p>
              </div>
            </div>
          </div>
          <div class="bg-white border border-gray-200 rounded-xl p-5">
            <div class="flex items-start gap-3">
              <span class="text-2xl mt-0.5">🔭</span>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Our Vision</h3>
                <p class="text-slate-600 text-sm leading-relaxed">A GTA where every small business has access to enterprise-grade IT and cybersecurity — regardless of size or budget.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section class="section-white">
    <div class="container-lg">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-3">What Makes WiseTech Different</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">There are dozens of IT companies in the GTA. Here is why Mississauga businesses choose WiseTech.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {differentiators.map(d => (
          <div class="card p-6 hover:shadow-md hover:border-cyan-400 transition-all">
            <div class="text-3xl mb-3">{d.icon}</div>
            <h3 class="font-bold text-slate-900 mb-2">{d.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{d.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section-slate">
    <div class="container-lg">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-3">Our Values</h2>
        <p class="text-slate-600 max-w-xl mx-auto">These are not words on a wall — they are how we make decisions every day.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
        {values.map(value => (
          <div class="card p-6 text-center hover:shadow-md hover:border-cyan-400 transition-all">
            <div class="text-3xl mb-3">{value.icon}</div>
            <h3 class="font-bold text-slate-900 mb-2">{value.name}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries We Understand -->
  <section class="section-white">
    <div class="container-lg max-w-4xl">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-extrabold text-slate-900 mb-3">Industries We Understand</h2>
        <p class="text-slate-600">We have deep experience with the specific IT and compliance requirements of these sectors.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: '⚖️', label: 'Legal & Law Firms', href: '/industries/law-firms' },
          { icon: '🦷', label: 'Dental & Healthcare', href: '/industries/dental-healthcare' },
          { icon: '📊', label: 'Accounting & Finance', href: '/industries/accounting-finance' },
          { icon: '🏠', label: 'Real Estate', href: '/industries/real-estate' },
          { icon: '🏭', label: 'Manufacturing', href: '/industries/manufacturing' },
          { icon: '🏨', label: 'Hospitality', href: '/industries/hospitality' },
          { icon: '🛍️', label: 'Retail & E-Commerce', href: '/industries/retail-ecommerce' },
          { icon: '🎓', label: 'Education', href: '/industries/education' },
        ].map(ind => (
          <a href={ind.href} class="card p-4 text-center hover:shadow-md hover:border-cyan-400 transition-all group">
            <div class="text-2xl mb-2">{ind.icon}</div>
            <div class="text-sm font-semibold text-slate-700 group-hover:text-cyan-600 transition-colors">{ind.label}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="section-slate">
    <div class="container-lg">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-extrabold text-slate-900 mb-3">Areas We Serve</h2>
        <p class="text-slate-600">Based in Mississauga, serving businesses across the Greater Toronto Area.</p>
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        {serviceAreas.map(area => (
          <span class="bg-white border border-gray-200 text-slate-700 font-medium text-sm px-5 py-2.5 rounded-full hover:border-cyan-400 hover:text-cyan-600 transition-all">
            📍 {area}
          </span>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    headline="Ready to Work With a Local IT Partner?"
    subtext="Book a free IT assessment — we will review your current setup and show you exactly how WiseTech can help."
  />

</PageLayout>
