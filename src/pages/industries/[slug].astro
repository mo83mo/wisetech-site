---
// src/pages/industries/[slug].astro
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import FAQ from '../../components/FAQ.astro';
import CTABanner from '../../components/CTABanner.astro';

export async function getStaticPaths() {
  const industries = await getCollection('industries');
  return industries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://wisetech.ca"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Industries",
      "item": "https://wisetech.ca/industries"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": data.title,
      "item": `https://wisetech.ca/industries/${entry.slug}`
    }
  ]
};
---

<PageLayout
  title={data.metaTitle}
  description={data.metaDescription}
  additionalSchema={breadcrumbSchema}
>

  <Hero
    breadcrumb={`Industries / ${data.title}`}
    headline={data.hero.headline}
    subheadline={data.hero.subheadline}
    ctaText="Get a Free Assessment"
    ctaHref="/contact"
    photo={data.hero.photo}
    photoAlt={data.hero.photoAlt}
  />

  <TrustBar items={data.trustBar} />

  <section class="section-white">
    <div class="container-lg">
      <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-8">
        What We Do for {data.title.replace('IT Support for ', '')}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {data.features.map(feature => (
          <div class="flex gap-4 items-start">
            <span class="text-cyan-400 font-bold text-xl mt-0.5 flex-shrink-0">✓</span>
            <div>
              <h3 class="font-semibold text-slate-900 mb-1">{feature.name}</h3>
              <p class="text-slate-600 text-sm leading-relaxed">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-slate">
    <div class="container-lg max-w-3xl">
      <div class="prose prose-slate prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-slate-900
        prose-a:text-cyan-600 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-slate-900">
        <Content />
      </div>
    </div>
  </section>

  <section class="section-white">
    <div class="container-lg">
      <h2 class="text-xl font-bold text-slate-900 mb-4">Related Services</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/services/managed-it" class="text-sm font-medium text-cyan-600 hover:text-cyan-500 bg-slate-50 border border-gray-200 px-4 py-2 rounded-full transition">Managed IT →</a>
        <a href="/services/cybersecurity" class="text-sm font-medium text-cyan-600 hover:text-cyan-500 bg-slate-50 border border-gray-200 px-4 py-2 rounded-full transition">Cybersecurity →</a>
        <a href="/services/backup-disaster-recovery" class="text-sm font-medium text-cyan-600 hover:text-cyan-500 bg-slate-50 border border-gray-200 px-4 py-2 rounded-full transition">Backup & DR →</a>
        <a href="/services/cloud-solutions" class="text-sm font-medium text-cyan-600 hover:text-cyan-500 bg-slate-50 border border-gray-200 px-4 py-2 rounded-full transition">Cloud Solutions →</a>
      </div>
    </div>
  </section>

  <FAQ faqs={data.faqs} />

  <CTABanner
    headline={data.ctaHeadline}
    subtext={data.ctaSubtext}
  />

</PageLayout>
