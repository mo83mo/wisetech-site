              <tr class="border-b border-gray-100 hover:bg-slate-50 transition">
                <td class="px-5 py-3 text-slate-700">Patch Management</td>
                <td class="text-center px-4 py-3 text-cyan-500">✓</td>
                <td class="text-center px-4 py-3 text-cyan-500 bg-navy-900/5">✓</td>
                <td class="text-center px-4 py-3 text-cyan-500">✓</td>
              </tr>
              <tr class="border-b border-gray-100 hover:bg-slate-50 transition">
                <td class="px-5 py-3 text-slate-700">Asset & Inventory Management</td>
                <td class="text-center px-4 py-3 text-cyan-500">✓</td>
                <td class="text-center px-4 py-3 text-cyan-500 bg-navy-900/5">✓</td>
                <td class="text-center px-4 py-3 text-cyan-500">✓</td>
              </tr>
              <tr class="border-b border-gray-100 hover:bg-slate-50 transition">
                <td class="px-5 py-3 text-slate-700">Quarterly Business Review</td>
                <td class="text-center px-4 py-3 text-slate-400">—</td>
