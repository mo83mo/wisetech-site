                <td class="text-center px-4 py-3 text-slate-400">—</td>
                <td class="text-center px-4 py-3 text-slate-600 bg-navy-900/5">Quarterly</td>
                <td class="text-center px-4 py-3 text-slate-900 font-semibold">Quarterly+</td>
              </tr>
              <tr class="border-b border-gray-100 hover:bg-slate-50 transition">
                <td class="px-5 py-3 text-slate-700">Managed Detection & Response (MDR)</td>
                <td class="text-center px-4 py-3 text-slate-400">—</td>
                <td class="text-center px-4 py-3 text-slate-400 bg-navy-900/5">—</td>
                <td class="text-center px-4 py-3 text-cyan-500">✓</td>
              </tr>
              <tr class="border-b border-gray-100 hover:bg-slate-50 transition">
