              </tr>
              <tr class="border-b border-gray-100 hover:bg-slate-50 transition">
                <td class="px-5 py-3 text-slate-700">Remote Helpdesk</td>
                <td class="text-center px-4 py-3 text-slate-600">Mon–Fri 8am–6pm</td>
                <td class="text-center px-4 py-3 font-semibold text-white bg-navy-900/5">24/7</td>
