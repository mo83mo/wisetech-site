            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left px-5 py-4 font-bold text-slate-700 bg-slate-50 w-1/2">Feature</th>
                <th class="text-center px-4 py-4 font-bold text-slate-700 bg-slate-50">Essential<br/><span class="text-cyan-500 font-extrabold">$99/user</span></th>
                <th class="text-center px-4 py-4 font-extrabold text-white bg-navy-900 relative">
                  <span class="block text-xs font-bold text-cyan-400 uppercase tracking-wider mb-0.5">Most Popular</span>
                  Professional<br/><span class="text-cyan-400 font-extrabold">$149/user</span>
                </th>
                <th class="text-center px-4 py-4 font-bold text-slate-700 bg-slate-50">Advanced<br/><span class="text-cyan-500 font-extrabold">$199/user</span></th>
              </tr>
            </thead>
            <tbody>
              <!-- HELPDESK -->
              <tr class="bg-slate-50 border-b border-gray-200">
