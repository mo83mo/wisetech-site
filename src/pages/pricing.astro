              type="number"
              id="calc-users"
              min="5"
              max="500"
              value="10"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 text-lg font-semibold focus:outline-none focus:ring-2 focus:ring-cyan-400 text-slate-900"
            />
