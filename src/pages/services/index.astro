---
// src/pages/services/index.astro
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTABanner from '../../components/CTABanner.astro';

const allServices = await getCollection('services');

const icons: Record<string, string> = {
  'managed-it': '🖥️',
  'cybersecurity': '🔒',
  'backup-disaster-recovery': '💾',
  'cloud-solutions': '☁️',
  'network-infrastructure': '🌐',
  'it-consulting': '💼',
  'voip-communications': '📞',
  'cctv-surveillance': '📷',
};

const order = [
  'managed-it',
  'cybersecurity',
  'backup-disaster-recovery',
  'cloud-solutions',
  'network-infrastructure',
  'it-consulting',
  'voip-communications',
  'cctv-surveillance',
];

const services = order.map(slug =>
  allServices.find(s => s.slug === slug)
).filter(Boolean);
---

<PageLayout
  title="Managed IT Services Mississauga | All Services | WiseTech"
  description="Browse WiseTech's full range of IT services for Mississauga and GTA businesses — managed IT, cybersecurity, cloud, backup, networking, consulting, VoIP, and CCTV."
>

  <Hero
    headline="IT Services for Mississauga Businesses"
    subheadline="From day-to-day helpdesk support to cybersecurity and cloud migrations — WiseTech provides the complete IT stack your business needs, managed by a local Mississauga team."
    ctaText="Get a Free Assessment"
    ctaHref="/contact"
    photo="https://images.unsplash.com/photo-1588702547923-7093a6c3ba33?w=600&h=400&fit=crop&auto=format"
    photoAlt="WiseTech IT services team in Mississauga"
  />

  <TrustBar />

  <section class="section-white">
    <div class="container-lg">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-3">All Services</h2>
        <p class="text-slate-600 max-w-xl mx-auto">Every service is delivered by our local Mississauga team with flat monthly pricing and no hidden fees.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {services.map(service => service && (
          <ServiceCard
            title={service.data.title}
            description={service.data.serviceSchema.description}
            icon={icons[service.slug] ?? '💻'}
            href={`/services/${service.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    headline="Not Sure Which Service You Need?"
    subtext="Book a free assessment and we will review your environment and recommend exactly what your Mississauga business needs — no obligation."
  />

</PageLayout>
