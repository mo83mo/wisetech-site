---
// src/pages/signin.astro
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Sign In | WiseTech Client Portal"
  description="Sign in to your WiseTech client portal to access your IT dashboard, support tickets, and account information."
>
  <div class="bg-hero-gradient min-h-[80vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">

      <div class="bg-white rounded-2xl shadow-2xl p-8">

        <div class="text-center mb-8">
          <img src="/images/logo-navy.jpg" alt="WiseTech" class="h-14 w-auto mx-auto mb-4" />
          <h1 class="text-2xl font-extrabold text-slate-900">Client Portal</h1>
          <p class="text-slate-500 text-sm mt-1">Sign in to your WiseTech account</p>
        </div>

        <div id="error-msg" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3 mb-5 flex items-center gap-2">
          <span>⚠️</span>
          <span>Incorrect username or password. Please try again.</span>
        </div>

        <form id="signin-form" class="flex flex-col gap-4">
          <div>
            <label for="email" class="block text-sm font-semibold text-slate-700 mb-1.5">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@yourcompany.ca"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:border-transparent"
            />
          </div>
          <div>
            <div class="flex justify-between items-center mb-1.5">
              <label for="password" class="block text-sm font-semibold text-slate-700">Password</label>
              <a href="/contact" class="text-xs text-cyan-500 hover:text-cyan-400 transition">Forgot password?</a>
            </div>
            <input
              type="password"
              id="password"
              name="password"
              required
              placeholder="••••••••"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:border-transparent"
            />
          </div>
          <button
            type="submit"
            class="btn-primary w-full text-center text-base py-3 mt-2"
          >
            Sign In
          </button>
        </form>

        <div class="mt-6 pt-6 border-t border-gray-100 text-center">
          <p class="text-sm text-slate-500">
            Not a client yet?
            <a href="/contact" class="text-cyan-500 font-semibold hover:text-cyan-400 transition">Book a free assessment →</a>
          </p>
        </div>

      </div>

      <p class="text-center text-slate-400 text-xs mt-4">
        Having trouble signing in? <a href="/contact" class="text-slate-300 hover:text-white transition underline">Contact support</a>
      </p>
    </div>
  </div>
</PageLayout>

<script>
  const form = document.getElementById('signin-form');
  const errorMsg = document.getElementById('error-msg');

  // Show error if redirected back with ?error=1
  if (window.location.search.includes('error=1') && errorMsg) {
    errorMsg.classList.remove('hidden');
    errorMsg.classList.add('flex');
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // Always show error — authentication not yet implemented
    window.location.href = '/signin?error=1';
  });
</script>
